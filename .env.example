# =============================================================================
# TeleFlow Environment Configuration
# WARNING: Never commit this file to version control. Create a copy as .env.
# =============================================================================

# Telegram Bot Token — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# JWT Secret — generate with: openssl rand -hex 64
JWT_SECRET=

# Base64-encoded proxy list (format: ip:port:username:password per line)
# Generate with: echo -n "$(cat proxy-list.txt | base64 -w0)"
PROXY_LIST_B64=

# Database
DATABASE_URL=postgres://teleflow:password@localhost:5432/teleflow?sslmode=disable

# Redis (for rate limiting + session cache)
REDIS_URL=redis://localhost:6379/0

# API Server
API_PORT=8080
API_HOST=0.0.0.0

# Telegram Bot Webhook URL (public-facing, e.g. https://api.teleflow.dev/webhook/tg)
TG_BOT_WEBHOOK_URL=

# Client version enforcement
MIN_CLIENT_VERSION=1.0.0

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Allowed origins for CORS
CORS_ORIGINS=*

# Rate limiting (requests per minute per user)
RATE_LIMIT_RPM=30
