<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">api.teleflow.dev</domain>
        <pin-set expiration="2027-01-01">
            <!-- Primary pin: SHA-256 of SubjectPublicKeyInfo -->
            <!-- Generate with: openssl s_client -connect api.teleflow.dev:443 | openssl x509 -pubkey -noout | openssl pkey -pubin -outform der | openssl dgst -sha256 -binary | base64 -->
            <pin digest="SHA-256">PLACEHOLDER_PIN_PRIMARY</pin>
            <!-- Backup pin for certificate rotation -->
            <pin digest="SHA-256">PLACEHOLDER_PIN_BACKUP</pin>
        </pin-set>
    </domain-config>

    <!-- Block all cleartext (HTTP) traffic -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
